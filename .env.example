# ============================================================
# Environment Variables — copy this file to .env.local
# and fill in your own values.
# ============================================================

# ------------------------------------
# Site URL
# The canonical public URL of your deployment (no trailing slash).
# Used for metadata, Open Graph tags, sitemap, and robots.txt.
# Example: https://www.example.com
# ------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.example.com

# ------------------------------------
# Google Analytics 4 (optional)
# Public GA4 Measurement ID (for example: G-XXXXXXXXXX).
# This is a browser-visible value, not a private secret.
# Leave empty or omit it to disable analytics entirely.
# ------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ------------------------------------
# Footer links (optional)
# If omitted, the corresponding link will not be rendered in the footer.
# ------------------------------------
NEXT_PUBLIC_SOLA_STUDIO_URL=https://your-studio-url.com
NEXT_PUBLIC_GITHUB_REPOSITORY_URL=https://github.com/your-org/contrastly